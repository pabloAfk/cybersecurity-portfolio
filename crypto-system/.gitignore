cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
*.egg

# Database
*.db
*.sqlite
*.sqlite3
database/*.db
!database/.gitkeep

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Docker
*.pid

# Secrets
secrets/
keys/
*.pem
*.key

# OS
Thumbs.db
.directory
EOF

# Cria .gitkeep para manter a pasta database vazia no git
mkdir -p database
touch database/.gitkeep
