# ============================================
# Educational Crypto System - Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores
# O .env NÃO será commitado (está no .gitignore)

# Database
# Opção 1: SQLite (padrão, mais simples)
DATABASE_URL=sqlite:///database/crypto.db

# Opção 2: PostgreSQL (via Docker, descomente se quiser)
# DATABASE_URL=postgresql://crypto_user:crypto_pass@postgres:5432/crypto_db

# Security - GERAR UMA CHAVE REAL!
# Execute: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Environment
ENVIRONMENT=development
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
